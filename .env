# Enviguide Frontend — environment
# DO NOT set VITE_API_BASE_URL here (this file is committed and gets baked into
# the PRODUCTION build). getApiBaseUrl() auto-detects the backend by hostname:
#   - on localhost / 127.0.0.1  -> http://localhost:8000
#   - anywhere else (prod)       -> https://enviguide.nextechltd.in
# For a custom LOCAL backend, put VITE_API_BASE_URL in `.env.local` (gitignored),
# NOT here — otherwise it ships to production and breaks live login.
# VITE_API_BASE_URL=http://localhost:8000
